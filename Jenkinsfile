                echo 'Clonando repositorio...'
            }
        }

        stage('Build') {
            steps {
                echo 'Construyendo proyecto...'
            }
        }

        stage('Test') {
            steps {
                echo 'Ejecutando tests...'
            }
        }
    }
}
